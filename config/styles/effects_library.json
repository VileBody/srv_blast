{
  "libraryVersion": "0.2",
  "meta": {
    "name": "AE Effects Library",
    "notes": "Effect presets + semantic styles for adjustment layers. semanticStyles encode meaning ('when to use') + a fixed effect stack + allowed override params. matchNamePath values use AE matchName strings."
  },
  "keyTemplates": {
    "tpl_linear": {
      "description": "Linear interpolation (in/out)",
      "inInterpolationType": 6612,
      "outInterpolationType": 6612
    },
    "tpl_hold": {
      "description": "Hold keyframes",
      "inInterpolationType": 6614,
      "outInterpolationType": 6614
    },
    "tpl_ease_in_out_soft": {
      "description": "Soft ease in/out (Bezier). influence~33",
      "inInterpolationType": 6613,
      "outInterpolationType": 6613,
      "inTemporalEase": [
        {
          "speed": 0,
          "influence": 33.333333
        }
      ],
      "outTemporalEase": [
        {
          "speed": 0,
          "influence": 33.333333
        }
      ],
      "temporalAutoBezier": false,
      "temporalContinuous": false
    },
    "tpl_impact_sharp": {
      "description": "Sharper impact ease (Bezier). influence high",
      "inInterpolationType": 6613,
      "outInterpolationType": 6613,
      "inTemporalEase": [
        {
          "speed": 0,
          "influence": 80
        }
      ],
      "outTemporalEase": [
        {
          "speed": 0,
          "influence": 80
        }
      ],
      "temporalAutoBezier": false,
      "temporalContinuous": false
    },
    "tpl_shake_oscillation": {
      "description": "Oscillation-ish (Bezier). Use with dense keys from impact/shake curves",
      "inInterpolationType": 6613,
      "outInterpolationType": 6613,
      "inTemporalEase": [
        {
          "speed": 0,
          "influence": 20
        }
      ],
      "outTemporalEase": [
        {
          "speed": 0,
          "influence": 20
        }
      ],
      "temporalAutoBezier": false,
      "temporalContinuous": false
    }
  },
