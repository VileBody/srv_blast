{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "type": "stat",
      "title": "Succeeded (1h)",
      "id": 1,
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(increase(job_lifecycle_total{status=\"succeeded\"}[1h]))", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "orientation": "auto"},
      "fieldConfig": {"defaults": {}, "overrides": []}
    },
    {
      "type": "stat",
      "title": "Failed (1h)",
      "id": 2,
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(increase(job_lifecycle_total{status=\"failed\"}[1h]))", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "orientation": "auto"},
      "fieldConfig": {"defaults": {}, "overrides": []}
    },
    {
      "type": "stat",
      "title": "Queue Depth (now)",
      "id": 3,
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "queue_depth", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "orientation": "auto"},
      "fieldConfig": {"defaults": {}, "overrides": []}
    },
    {
      "type": "stat",
      "title": "Failed Ratio (10m)",
      "id": 4,
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(increase(job_lifecycle_total{status=\"failed\"}[10m])) / clamp_min(sum(increase(job_lifecycle_total{status=~\"succeeded|failed\"}[10m])), 1)", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "orientation": "auto"},
      "fieldConfig": {"defaults": {"unit": "percentunit"}, "overrides": []}
    },
    {
      "type": "timeseries",
      "title": "Queue + Inflight",
      "id": 5,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "queue_depth", "legendFormat": "queue_depth", "refId": "A"},
        {"expr": "inflight_jobs", "legendFormat": "inflight_jobs", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "type": "timeseries",
      "title": "Stage Latency p50/p95",
      "id": 6,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by (le, stage) (rate(stage_duration_seconds_bucket[15m])))", "legendFormat": "p50 {{stage}}", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le, stage) (rate(stage_duration_seconds_bucket[15m])))", "legendFormat": "p95 {{stage}}", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}}
    },
    {
      "type": "timeseries",
      "title": "Lifecycle Throughput",
      "id": 7,
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum by (status) (rate(job_lifecycle_total[5m]))", "legendFormat": "{{status}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}}
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["blast", "pipeline"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "timezone": "browser",
  "title": "Pipeline Overview",
  "version": 1
}
