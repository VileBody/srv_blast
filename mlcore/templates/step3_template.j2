{# mlcore/templates/step3_template.j2 #}
{
  "version": "v1",
  "main_comp_name": "Comp 1",

  "main_comp_w": {{ main_comp_w }},
  "main_comp_h": {{ main_comp_h }},

  {# FPS is optional (for backward compatibility); default is AE dump FPS #}
  "main_comp_fps": {{ main_comp_fps | default(23.9759979248047) }},

  "text_dur_hint": {{ text_dur_hint }},

  "adjustment_preset": {{ adjustment_preset | tojson }},

  {# Optional diagnostics contract (safe to ignore downstream) #}
  "diagnostics": {
    "enabled": {% if diagnostics is defined and diagnostics.enabled %}true{% else %}false{% endif %},
    "app_dir": {% if diagnostics is defined and diagnostics.app_dir is defined %}{{ diagnostics.app_dir | tojson }}{% else %}null{% endif %},
    "hb_file": {% if diagnostics is defined and diagnostics.hb_file is defined %}{{ diagnostics.hb_file | tojson }}{% else %}"hb.txt"{% endif %},
    "live_log_file": {% if diagnostics is defined and diagnostics.live_log_file is defined %}{{ diagnostics.live_log_file | tojson }}{% else %}"run_live.log"{% endif %},
    "timeout_total_sec": {% if diagnostics is defined and diagnostics.timeout_total_sec is defined %}{{ diagnostics.timeout_total_sec }}{% else %}0{% endif %},
    "timeout_per_layer_sec": {% if diagnostics is defined and diagnostics.timeout_per_layer_sec is defined %}{{ diagnostics.timeout_per_layer_sec }}{% else %}0{% endif %},
    "abort_on_timeout": {% if diagnostics is defined and diagnostics.abort_on_timeout %}true{% else %}false{% endif %}
  },

  "limits": {
    "min_layer_dur_frames": {% if limits is defined and limits.min_layer_dur_frames is defined %}{{ limits.min_layer_dur_frames }}{% else %}1{% endif %}
  },

  "layers": [
    {# --- Footage clips --- #}
    {%- set fps = main_comp_fps | default(23.9759979248047) %}
    {%- set eps = (1.0 / fps) %}

    {%- for c in footage.clips %}
    {
      "layer_id": {{ ("footage_" ~ loop.index0) | tojson }},
      "diag_tag": {{ ("FOOTAGE[" ~ loop.index0 ~ "] " ~ c.file_name) | tojson }},

      "type": "footage",
      "name": {{ c.file_name | tojson }},
      "file_name": {{ c.file_name | tojson }},
      "file_path": {{ assets_map[c.file_name].file_path | tojson }},

      "src_w": {{ assets_map[c.file_name].src_w }},
      "src_h": {{ assets_map[c.file_name].src_h }},
      "fit_mode": {{ c.fit_mode | tojson }},

      "in_point": {{ c.in_point }},
      "out_point": {% if c.out_point <= c.in_point %}{{ c.in_point + eps }}{% else %}{{ c.out_point }}{% endif %},
      "start_time": {{ c.start_time }},

      "enabled": true,
      "audio_enabled": false,
      "video_enabled": true,
      "target_comp": "Comp 1"
    }{% if not loop.last %},{% endif %}
    {%- endfor %}
    {% if footage.clips | length > 0 %},
    {% endif %}

    {# --- AUDIO LAYER (Windows-relocatable mode supported via audio_file_path) --- #}
    {
      "layer_id": "audio_ref",
      "diag_tag": "AUDIO реф",

      "type": "audio_only",
      "name": "реф",
      "file_name": {{ audio_file_name | tojson }},
      "file_path": {{ audio_file_path | tojson }},

      "in_point": {{ audio.layer_in_point }},
      "out_point": {% if audio.layer_out_point <= audio.layer_in_point %}{{ audio.layer_in_point + eps }}{% else %}{{ audio.layer_out_point }}{% endif %},
      "start_time": {{ audio.layer_start_time }},

      "enabled": true,
      "audio_enabled": true,
      "video_enabled": false,
      "moment_of_interest_sec": {% if audio.moment_of_interest_sec is none %}null{% else %}{{ audio.moment_of_interest_sec }}{% endif %},
      "target_comp": "Comp 1"
    }
  ]
}
