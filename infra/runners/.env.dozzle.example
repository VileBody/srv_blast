DOZZLE_BIND_HOST=127.0.0.1
DOZZLE_PORT=18080
DOZZLE_AUTH_PROVIDER=none
DOZZLE_BASE=/logs
DOZZLE_HOSTNAME=blast-ops
# Optional comma-separated agent endpoints for other Docker hosts.
# Current split-prod default is bootstrapped by deploy_branch.sh when this is empty.
# Example: DOZZLE_REMOTE_AGENT=192.168.0.8:7007,192.168.0.11:7007
DOZZLE_REMOTE_AGENT=
