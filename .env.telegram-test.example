# Telegram test-environment override.
# Store the filled runtime file on blast-ops as `/opt/blast/telegram-test/.env`.
# Do not commit real tokens, API hashes, session strings, DB URLs, or SSH paths.

TG_TEST_CONTROL_DIR=/opt/blast/telegram-test

TG_BOT_API_ENV=test
TG_DELIVERY_MODE=webhook
TG_WEBHOOK_URL=https://blast808.com
TG_WEBHOOK_SECRET=<fill-test-webhook-secret>
TG_WEBHOOK_PATH=/telegram/webhook

TG_TEST_BOT_TOKEN=<fill-test-bot-token-from-test-botfather>
TG_TEST_BOT_USERNAME=<fill-test-bot-username-without-at>
TG_TEST_BYPASS_SUBSCRIPTION=1
TG_TEST_CREDITS_DB_URL=<postgresql://user:password@host:5432/blast_tg_test?sslmode=prefer>
TG_TEST_ADMIN_DB_URL=
TG_TEST_PREVIEW_SOURCE_BOT_TOKEN=

TG_PUBLIC_STATE_PREFIX=blast:tg:test:public:chat_state
TG_MAINTENANCE_STATE_KEY=blast:tg:test:maintenance_mode
BOT_TMP_DIR_PUBLIC=/app/work/tg_tmp_public_test

# Blast-ops control-plane endpoints.
TG_TEST_ORCHESTRATOR_URL=https://blast808.com/orchestrator
TG_TEST_REMOTE_ENV_PATH=.env.telegram-test
TG_TEST_SWITCH_VERIFY_DELAY_S=5

# Explicit SSH fan-out from blast-ops to orchestrator nodes. Do not rely on local SSH aliases.
TG_TEST_NODE0_NAME=orchestrator-0
TG_TEST_NODE0_HOST=<fill-orchestrator-0-host>
TG_TEST_NODE0_USER=deploy
TG_TEST_NODE0_PORT=22
TG_TEST_NODE0_REPO_DIR=<fill-orchestrator-0-repo-dir>
TG_TEST_NODE0_SSH_KEY_PATH=<fill-local-key-path-on-blast-ops>
TG_TEST_NODE1_NAME=orchestrator-1
TG_TEST_NODE1_HOST=<fill-orchestrator-1-host>
TG_TEST_NODE1_USER=deploy
TG_TEST_NODE1_PORT=22
TG_TEST_NODE1_REPO_DIR=<fill-orchestrator-1-repo-dir>
TG_TEST_NODE1_SSH_KEY_PATH=<fill-local-key-path-on-blast-ops>

# Telethon test DC/users.
TG_TEST_API_ID=<fill-test-api-id>
TG_TEST_API_HASH=<fill-test-api-hash>
TG_TEST_OWNER_SESSION_STRING=
TG_TEST_DC_ID=2
TG_TEST_DC_HOST=149.154.167.40
TG_TEST_DC_PORT=80
TG_TEST_CODE_LENGTH=5
TG_TEST_OWNER_PHONE_SUFFIX=9000
TG_TEST_BOT_NAME=Blast Test Bot
TG_TEST_BOT_USERNAME_CANDIDATE=blasttestbot
TG_TEST_USER_COUNT=50
TG_TEST_USER_CONCURRENCY=10
TG_TEST_SESSION_DIR=/opt/blast/telegram-test/sessions
TG_TEST_PHONE_SUFFIX_START=1000

# Load scenario.
TG_TEST_AUDIO_PATH=<path-to-local-audio-file>
TG_TEST_FOOTAGE_GENRE_LABEL=<fill-visible-genre-button>
TG_TEST_FOOTAGE_ARTIST_LABEL=<fill-visible-style-button>
TG_TEST_RUN_TIMEOUT_S=7200
