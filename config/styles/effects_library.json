{
  "libraryVersion": "0.3",
  "meta": {
    "createdAt": "2025-12-17",
    "notes": [
      "Semantic catalog of adjustment-layer effect styles.",
      "LLM выбирает effectStyleId (строго из списка), а keyframes retime'ятся через t∈[0..1] внутри окна слоя.",
      "Пока не трогаем 'интенсивности' (значения); модель может менять только t/time у keyframes, оставляя value как в пресете."
    ]
  },
  "keyTemplates": {
    "tpl_linear": {
      "interp": "linear",
      "temporalEase": null
    }
  },
  "effectPresets": {
    "ef_bcc_lens_blur": {
      "description": "BCC Lens Blur – iris/focus pulse",
      "propertyTree": {
        "matchName": "BCC6LensBlur",
        "name": "BCC Lens Blur"
      },
      "exposedParams": [
        {
          "key": "iris_scale",
          "matchNamePath": "BCC6LensBlur-9961714",
          "meaning": "Iris Scale (blur amount proxy)"
        },
        {
          "key": "gamma",
          "matchNamePath": "BCC6LensBlur-9961786",
          "meaning": "Gamma"
        }
      ],
      "paramMeta": {
        "iris_scale": {
          "type": "float"
        },
        "gamma": {
          "type": "float"
        }
      }
    },
    "ef_curves": {
      "description": "Curves – in AE this is often CUSTOM_VALUE; keep as placeholder for look parity",
      "propertyTree": {
        "matchName": "ADBE CurvesCustom",
        "name": "Curves"
      },
      "exposedParams": [],
      "paramMeta": {}
    },
    "ef_transform_geo": {
      "description": "Transform (Geometry2) – scale/pos/rotation. Used both for squash/stretch and shake driver.",
      "propertyTree": {
        "matchName": "ADBE Geometry2",
        "name": "Transform"
      },
      "exposedParams": [
        {
          "key": "position",
          "matchNamePath": "ADBE Geometry2-0002",
          "meaning": "Position"
        },
        {
          "key": "scale_height",
          "matchNamePath": "ADBE Geometry2-0003",
          "meaning": "Scale Height"
        },
        {
          "key": "scale_width",
          "matchNamePath": "ADBE Geometry2-0004",
          "meaning": "Scale Width"
        },
        {
          "key": "rotation",
          "matchNamePath": "ADBE Geometry2-0007",
          "meaning": "Rotation"
        }
      ],
      "paramMeta": {
        "position": {
          "type": "vec2"
        },
        "scale_height": {
          "type": "float"
        },
        "scale_width": {
          "type": "float"
        },
        "rotation": {
          "type": "float"
        }
      }
    },
    "ef_s_blurmotion": {
      "description": "Sapphire BlurMotion – zoom/center based blur",
      "propertyTree": {
        "matchName": "S_BlurMotion",
        "name": "S_BlurMotion"
      },
      "exposedParams": [
        {
          "key": "center",
          "matchNamePath": "S_BlurMotion-0050",
          "meaning": "Center"
        },
        {
          "key": "z_dist",
          "matchNamePath": "S_BlurMotion-0051",
          "meaning": "From Z Dist (zoom amount)"
        }
      ],
      "paramMeta": {
        "center": {
          "type": "vec2"
        },
        "z_dist": {
          "type": "float"
        }
      }
    },
    "ef_deep_glow": {
      "description": "Plugin Deep Glow – halo around text",
      "propertyTree": {
        "matchName": "PEDG",
        "name": "Deep Glow"
      },
      "exposedParams": [
        {
          "key": "radius",
          "matchNamePath": "PEDG-0001",
