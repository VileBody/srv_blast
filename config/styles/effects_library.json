  "semanticStyles": {
    "fx_none": {
      "meaning": {
        "label": "NONE / clean",
        "useWhen": [
          "нет акцента, просто читать/смотреть"
        ],
        "avoidWhen": [
          "нужно подчеркнуть пик/удар"
        ]
      },
      "effects": []
    },
    "fx_default_glow_v1": {
      "meaning": {
        "label": "DEFAULT / consistent glow",
        "useWhen": [
          "почти весь трек как базовый look",
          "нужен мягкий стиль, но без 'ударов'"
        ],
        "avoidWhen": [
          "очень грязный/агрессивный клип, где glow мешает деталям"
        ]
      },
      "effects": [
        {
          "id": "deep_glow",
          "presetId": "ef_deep_glow",
          "allowedParams": [
            "radius",
            "exposure",
            "threshold"
          ],
          "defaultOverrides": {
            "radius": 750,
            "exposure": 0.025,
            "threshold": 0
          }
        }
      ]
    },
    "fx_emphasis_soft_v1": {
      "meaning": {
        "label": "SOFT EMPHASIS / small accent",
        "useWhen": [
          "важное слово без жёсткого конфликта",
          "лёгкий подъём энергии",
          "подчеркнуть окончание фразы"
        ],
        "avoidWhen": [
          "жёсткий дроп/обвинение (там нужен DROP)",
          "момент тишины/шёпота"
        ]
      },
      "effects": [
        {
          "id": "transform",
          "presetId": "ef_transform_geo",
          "allowedParams": [
            "scale_height",
            "scale_width",
            "rotation"
          ],
          "overrideGuidance": {
            "scale_height": "quick bump: 100 -> (110..140) -> 100 inside window",
            "rotation": "optional tiny tilt (<= 3deg) if needed"
          },
          "defaultOverrides": {
            "scale_width": 100,
            "scale_height": 100,
            "rotation": 0
          }
        },
        {
          "id": "dir_blur",
          "presetId": "ef_dir_blur",
          "allowedParams": [
            "direction",
            "blur_length"
          ],
          "overrideGuidance": {
            "blur_length": "short smear on peaks only (0..60)"
          },
          "defaultOverrides": {
            "direction": 90,
            "blur_length": 0
          }
        }
      ]
    },
    "fx_drop_ultrahardbass_v1": {
      "meaning": {
        "label": "DROP / удар / 'ультрахардбасс'",
        "useWhen": [
          "обвинение/конфликт/надлом",
          "смысловой удар (drop)",
          "резкий поворот или кульминация"
        ],
        "avoidWhen": [
          "ровная подача без пиков",
          "очень длинные спокойные фразы"
        ]
      },
      "effects": [
        {
          "id": "lens_blur",
          "presetId": "ef_bcc_lens_blur",
          "allowedParams": [
            "iris_scale",
            "gamma"
          ],
          "overrideGuidance": {
            "iris_scale": "classic squeeze: high -> 0 -> 0 -> high; hold at 0 across middle",
            "gamma": "usually keep static"
          },
          "defaultOverrides": {
            "gamma": 1.0
          }
        },
        {
          "id": "curves",
          "presetId": "ef_curves",
          "allowedParams": [],
          "defaultOverrides": {}
        },
        {
          "id": "transform_main",
          "presetId": "ef_transform_geo",
          "allowedParams": [
            "scale_height",
            "scale_width"
          ],
          "overrideGuidance": {
            "scale_height": "squash: (200..300) -> 100 -> 100 -> (200..300)",
            "scale_width": "usually keep 100 unless you want stretch"
          },
          "defaultOverrides": {
            "scale_width": 100,
            "scale_height": 100
          }
        },
        {
          "id": "transform_shake",
          "presetId": "ef_transform_geo",
          "allowedParams": [
            "position"
          ],
          "overrideGuidance": {
            "position": "use 2-6 keys around impact; expression does decay"
          },
          "defaultOverrides": {
            "position": {
              "expression": "n=0;\r\nif (numKeys > 0 ){\r\nn = nearestKey(time) .index;\r\nif (key(n) .time > time ){\r\nn--;\r\n}\r\n}\r\nif (n == 0 ){\r\nt = 0;\r\n}else {\r\nt = time - key(n) .time;\r\n}\r\nif (n > 0 && t < 1){\r\nv = velocityAtTime (key(n) .time - thisComp.frameDuration/10);\r\namp = .02;\r\nfreq = 2.0;\r\ndecay = 6.0;\r\nvalue + v*amp*Math.sin\r\n(freq*t*2*Math.PI)/Math.exp(decay*t);\r\n}else{\r\nvalue;\r\n}"
            }
          }
        },
        {
          "id": "zoom_blur",
          "presetId": "ef_s_blurmotion",
          "allowedParams": [
            "z_dist",
            "center_xy"
          ],
          "overrideGuidance": {
            "z_dist": "zoom pulse: low -> high -> high -> low",
            "center_xy": "usually stay at comp center; animate only if needed"
          },
          "defaultOverrides": {
            "z_dist": 0.0
          }
        }
      ]
    }
  }
}
