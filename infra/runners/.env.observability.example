# Bind host for local-only access behind nginx reverse proxy
OBS_BIND_HOST=127.0.0.1

# Ports
GRAFANA_PORT=13000
PROMETHEUS_PORT=19090
ALERTMANAGER_PORT=19093
LOKI_PORT=13100

# Credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme
# If true, Grafana won't ask second login behind nginx basic auth.
GRAFANA_ANONYMOUS_ENABLED=true
GRAFANA_ANONYMOUS_ORG_ROLE=Viewer
GRAFANA_DISABLE_LOGIN_FORM=true

# Storage / retention
PROMETHEUS_RETENTION=30d
LOKI_RETENTION=744h

# External URLs for nginx subpath publication.
# IMPORTANT: without these values Grafana may redirect to "/" after login and return 404.
GRAFANA_ROOT_URL=https://blast808.com/admin/obs/grafana/
GRAFANA_SERVE_FROM_SUB_PATH=true
PROMETHEUS_EXTERNAL_URL=https://blast808.com/admin/obs/prometheus/
PROMETHEUS_ROUTE_PREFIX=/
ALERTMANAGER_EXTERNAL_URL=https://blast808.com/admin/obs/alertmanager/

# Runtime labels
OBS_ENV=prod

# Existing app docker network (must include orchestrator containers)
BLAST_DOCKER_NETWORK=blast_final_default

# Alertmanager -> Telegram
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
