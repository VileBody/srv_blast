# Paste inside your `server {}` block for blast808.com
# Assumes observability stack is bound to localhost only.
# Reuse the same Basic Auth file as /admin and /logs.

location /admin/obs/grafana/ {
    auth_basic "Blast Backoffice";
    auth_basic_user_file /etc/nginx/.htpasswd_backoffice;

    proxy_pass http://127.0.0.1:13000/;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
}

location /admin/obs/prometheus/ {
    auth_basic "Blast Backoffice";
    auth_basic_user_file /etc/nginx/.htpasswd_backoffice;

    proxy_pass http://127.0.0.1:19090/;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
}

location /admin/obs/alertmanager/ {
    auth_basic "Blast Backoffice";
    auth_basic_user_file /etc/nginx/.htpasswd_backoffice;

    proxy_pass http://127.0.0.1:19093/;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
}
