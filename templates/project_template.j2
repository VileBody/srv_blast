{# templates/project_template.j2 #}
(function () {
  app.beginUndoGroup("AE_TEXTLIB_FULL_PROJECT");

  // ==========================================================
  // 0) ENV / STATUS helpers
  // ==========================================================
  var __APP_DIR = "";
  try { __APP_DIR = $.getenv("APP_DIR"); } catch(e) { __APP_DIR = ""; }
  if (!__APP_DIR || __APP_DIR === "") {
    try {
      if ($.fileName) {
        var __f = new File($.fileName);
        __APP_DIR = __f.parent.fsName;
      }
    } catch(_) {}
  }
  if (!__APP_DIR || __APP_DIR === "") {
    try { __APP_DIR = Folder.temp.fsName; } catch(_) { __APP_DIR = ""; }
  }

  function __ensureFolderByPath(fsPath) {
    try {
      var fld = new Folder(fsPath);
      if (!fld.exists) fld.create();
      return fld.exists;
    } catch(e) { return false; }
  }

  function __writeAeStatusOk(aepFsName, compName) {
    try {
      var st = new File(__APP_DIR + "/ae_status.txt");
      st.encoding = "UTF-8";
      if (st.open("w")) {
        st.writeln("OK");
        st.writeln("aep=" + String(aepFsName || ""));
        st.writeln("compName=" + String(compName || ""));
        st.close();
      }
    } catch(e) {}
  }

  function __writeAeStatusErr(msg) {
    try {
      var st = new File(__APP_DIR + "/ae_status.txt");
      st.encoding = "UTF-8";
      if (st.open("w")) {
        st.writeln("ERROR");
        st.writeln(String(msg || "unknown error"));
        st.close();
      }
    } catch(e) {}
  }

  // suppress hidden modal dialogs (helps with BCC trial/alerts etc.)
  try { app.beginSuppressDialogs(); } catch(_) {}

  try {
    // ==========================================================
    // 0) PAYLOAD FROM PYTHON
    // ==========================================================
    var projectSpec = {{ project | tojson }};
    var compsSpec = {{ comps | tojson }};
    var footage_layers = {{ footage_layers | tojson }};
    var text_layers = {{ text_layers | tojson }};

    // ==========================================================
    // 0) LOGGER
    // ==========================================================
    function pad2(n) { return (n < 10) ? ("0" + n) : ("" + n); }
    function nowStamp() {
      var d = new Date();
      return (
        d.getFullYear() + "-" +
        pad2(d.getMonth() + 1) + "-" +
        pad2(d.getDate()) + "__" +
        pad2(d.getHours()) + "-" +
        pad2(d.getMinutes()) + "-" +
        pad2(d.getSeconds())
      );
    }

    var __LOG_ENABLED = true;
    var __LOG_FILE = null;
    var __LIVE_LOG_FILE = null;
    var __HB_FILE = null;
    var __LAST_HB = "";
    var __LOG_SEQ = 0;

    function getScriptFolder() {
      try {
        if ($.fileName) {
          var f = new File($.fileName);
          return f.parent;
        }
      } catch(e) {}
      return null;
    }

    function ensureFolder(folder) {
      try {
        if (folder && !folder.exists) folder.create();
        return folder && folder.exists;
      } catch(e) { return false; }
    }

    function initLogger() {
      try {
        var scriptFolder = getScriptFolder();
        var base = scriptFolder ? scriptFolder : Folder.userData;

        var logsFolder = new Folder(base.fsName + "/logs");
        if (!ensureFolder(logsFolder)) {
          logsFolder = new Folder(Folder.temp.fsName + "/ae_textlib_logs");
          ensureFolder(logsFolder);
        }

        var logPath = logsFolder.fsName + "/render_full_" + nowStamp() + ".log";
        __LOG_FILE = new File(logPath);
        __LOG_FILE.encoding = "UTF-8";
        __LIVE_LOG_FILE = new File(String(__APP_DIR || "") + "/run_live.log");
        __LIVE_LOG_FILE.encoding = "UTF-8";
        __HB_FILE = new File(String(__APP_DIR || "") + "/hb.txt");
        __HB_FILE.encoding = "UTF-8";

        if (__LOG_FILE.open("a")) {
          __LOG_FILE.writeln("=== AE FULL PROJECT LOG START ===");
          __LOG_FILE.writeln("time=" + (new Date()).toUTCString());
          __LOG_FILE.writeln("script=" + ($.fileName ? $.fileName : "<unknown>"));
          __LOG_FILE.writeln("logs_dir=" + logsFolder.fsName);
          __LOG_FILE.writeln("ae_version=" + app.version);
          __LOG_FILE.writeln("=================================");
          __LOG_FILE.close();
        }
        if (__LIVE_LOG_FILE && __LIVE_LOG_FILE.open("w")) {
          __LIVE_LOG_FILE.writeln("=== AE LIVE LOG START ===");
          __LIVE_LOG_FILE.writeln("time=" + (new Date()).toUTCString());
          __LIVE_LOG_FILE.close();
        }
      } catch(e) {
        __LOG_ENABLED = false;
      }
    }

    function _writeToFile(line) {
      if (!__LOG_ENABLED || !__LOG_FILE) return;
      try {
        if (__LOG_FILE.open("a")) {
          __LOG_FILE.writeln(line);
          __LOG_FILE.close();
        }
      } catch(e) {
        __LOG_ENABLED = false;
      }
    }

    function _writeLive(line) {
      if (!__LIVE_LOG_FILE) return;
      try {
        if (__LIVE_LOG_FILE.open("a")) {
          __LIVE_LOG_FILE.writeln(line);
          __LIVE_LOG_FILE.close();
        }
      } catch(_) {}
    }

    function _writeHeartbeat(layerName, phase) {
      try {
        __LAST_HB = "layer=" + String(layerName || "") + " phase=" + String(phase || "") + " ts=" + (new Date()).toUTCString();
        if (__HB_FILE && __HB_FILE.open("w")) {
          __HB_FILE.writeln(__LAST_HB);
          __HB_FILE.close();
        }
        _writeLive("[HB] " + __LAST_HB);
      } catch(_) {}
    }

    function phaseStart(layerName, phase) {
      var msg = "PHASE_START layer=" + String(layerName || "") + " phase=" + String(phase || "");
      logLine("INFO", msg);
      _writeHeartbeat(layerName, phase);
    }

    function phaseDone(layerName, phase) {
      var msg = "PHASE_DONE layer=" + String(layerName || "") + " phase=" + String(phase || "");
      logLine("INFO", msg);
      _writeHeartbeat(layerName, phase + "_done");
    }

    function logLine(level, msg) {
      __LOG_SEQ += 1;
      var line = "[" + level + "][" + __LOG_SEQ + "] " + msg;
      try { $.writeln(line); } catch(e) {}
      _writeToFile(line);
      _writeLive(line);
    }

    function logErr(prefix, e) {
      var s = prefix + ": " + (e && e.toString ? e.toString() : String(e));
      logLine("ERR", s);
      try {
        if (e && e.line) logLine("ERR", "line=" + e.line);
        if (e && e.fileName) logLine("ERR", "file=" + e.fileName);
      } catch(_) {}
    }

    function safeJson(v, maxLen) {
      var s = "";
      try { s = JSON.stringify(v); }
      catch(e) { try { s = String(v); } catch(_) { s = "<unstringifiable>"; } }
      if (maxLen && s.length > maxLen) s = s.substring(0, maxLen) + "...<trunc>";
      return s;
    }

    function pick(obj, a, b) {
      if (obj && obj[a] !== undefined && obj[a] !== null) return obj[a];
      if (obj && obj[b] !== undefined && obj[b] !== null) return obj[b];
      return undefined;
    }

    function fmtNum(n) {
      if (n === undefined) return "undefined";
      if (n === null) return "null";
      try { return Number(n).toFixed(6); } catch(e) { return String(n); }
    }

    initLogger();
    logLine("INFO", "start FULL footage_layers=" + (footage_layers ? footage_layers.length : 0) + " text_layers=" + (text_layers ? text_layers.length : 0));
    logLine("DBG", "projectSpec=" + safeJson(projectSpec, 400));
    logLine("DBG", "compsSpec=" + safeJson(compsSpec, 400));
    logLine("DBG", "APP_DIR=" + String(__APP_DIR));

    // ==========================================================
    // 1) PROJECT + COMPS
    // ==========================================================
    var project = app.project;
    if (!project) { logLine("ERR", "no app.project"); throw new Error("no app.project"); }

    function findCompByName(name) {
      try {
        for (var i = 1; i <= project.numItems; i++) {
          var it = project.item(i);
          if (it instanceof CompItem && it.name === name) return it;
        }
      } catch(e) {}
      return null;
    }

    function findFootageByName(name) {
      try {
        for (var i = 1; i <= project.numItems; i++) {
          var it = project.item(i);
          if (it instanceof FootageItem && it.name === name) return it;
        }
      } catch(e) {}
      return null;
    }

    function ensureComp(spec) {
      var c = findCompByName(spec.name);
      if (!c) {
        try {
          var pa = (spec.pixelAspect !== undefined && spec.pixelAspect !== null) ? spec.pixelAspect : 1.0;
          c = project.items.addComp(spec.name, spec.w, spec.h, pa, spec.dur, spec.fps);
          logLine("INFO", "comp created name=" + spec.name);
        } catch(e) {
          logErr("create comp failed name=" + spec.name, e);
          return null;
        }
      }
      // Keep comp dimensions in sync with the spec even if the comp already existed
      // (e.g. when re-running JSX in the same AE project after switching from 1:1 -> 9:16).
      try {
        if (spec.w !== undefined && spec.h !== undefined) {
          var _w0 = Number(c.width), _h0 = Number(c.height);
          var _w1 = Number(spec.w), _h1 = Number(spec.h);
          if (!isNaN(_w0) && !isNaN(_h0) && !isNaN(_w1) && !isNaN(_h1) && (_w0 !== _w1 || _h0 !== _h1)) {
            try { c.width = _w1; } catch(_) {}
            try { c.height = _h1; } catch(_) {}
            logLine("INFO", "comp resized name=" + spec.name + " " + _w0 + "x" + _h0 + " -> " + _w1 + "x" + _h1);
          }
        }
      } catch(_) {}
      try { if (spec.fps !== undefined) c.frameRate = spec.fps; } catch(_) {}
      try { if (spec.dur !== undefined) c.duration = spec.dur; } catch(_) {}
      try { if (spec.workAreaStart !== undefined) c.workAreaStart = spec.workAreaStart; } catch(_) {}
      try { if (spec.workAreaDuration !== undefined) c.workAreaDuration = spec.workAreaDuration; } catch(_) {}
      try { if (spec.displayStartTime !== undefined) c.displayStartTime = spec.displayStartTime; } catch(_) {}
      try { if (spec.bgColor && spec.bgColor.length === 3) c.bgColor = spec.bgColor; } catch(_) {}
      return c;
    }

    var __COMPS = {};
    for (var ci = 0; ci < compsSpec.length; ci++) {
      var cc = ensureComp(compsSpec[ci]);
      if (cc) __COMPS[cc.name] = cc;
    }

    var MAIN_COMP = __COMPS[projectSpec.mainCompName] || findCompByName(projectSpec.mainCompName);
    if (!MAIN_COMP) { logLine("ERR", "main comp missing=" + projectSpec.mainCompName); throw new Error("main comp missing"); }

    // IMPORTANT: no openInViewer() on render nodes

    // ==========================================================
    // 1.05) Expand precomp nodes in text_layers
    // ==========================================================
    function ensureCompByNameStrict(meta) {
      if (!meta || !meta.name) return null;

      var c = __COMPS[String(meta.name)] || findCompByName(String(meta.name));
      if (c) {
        // Same as ensureComp(): keep node precomp dimensions in sync when re-running scripts.
        try {
          var _mw = Number(meta.w || 1080), _mh = Number(meta.h || 1920);
          var _w0 = Number(c.width), _h0 = Number(c.height);
          if (!isNaN(_w0) && !isNaN(_h0) && !isNaN(_mw) && !isNaN(_mh) && (_w0 !== _mw || _h0 !== _mh)) {
            try { c.width = _mw; } catch(_) {}
            try { c.height = _mh; } catch(_) {}
            logLine("INFO", "precomp resized (node) name=" + c.name + " " + _w0 + "x" + _h0 + " -> " + _mw + "x" + _mh);
          }
        } catch(_) {}
        __COMPS[c.name] = c;
        return c;
      }

      try {
        c = project.items.addComp(
          String(meta.name),
          Number(meta.w || 1080),
          Number(meta.h || 1920),
          1.0,
          Number(meta.dur || 5.0),
          Number(meta.fps || 23.976)
        );
        try { if (meta.fps !== undefined) c.frameRate = meta.fps; } catch(_) {}
        try { if (meta.dur !== undefined) c.duration = meta.dur; } catch(_) {}
        __COMPS[c.name] = c;
        logLine("INFO", "precomp created (node) name=" + c.name + " id=" + c.id);
        return c;
      } catch(e) {
        logErr("precomp create failed (node) name=" + String(meta.name), e);
        return null;
      }
    }

    function expandPrecompNodes(list) {
      var out = [];
      try {
        for (var i = 0; i < list.length; i++) {
          var it = list[i];

          if (it && it.type === "precomp" && it.comp && it.layers && it.layers.length !== undefined) {
            var pc = ensureCompByNameStrict(it.comp);
            if (!pc) continue;

            for (var j = 0; j < it.layers.length; j++) {
              var inner = it.layers[j];
              if (!inner) continue;

              if (!inner.text_data) inner.text_data = {};
              if (!inner.text_data.layer_meta) inner.text_data.layer_meta = {};
              inner.text_data.layer_meta.comp_name_target = pc.name;

              out.push(inner);
            }
            continue;
          }
          out.push(it);
        }
      } catch(eExp) {
        logErr("expandPrecompNodes failed", eExp);
        return list;
      }
      return out;
    }

    text_layers = expandPrecompNodes(text_layers);
    logLine("INFO", "text_layers expanded=" + (text_layers ? text_layers.length : 0));

    // ==========================================================
    // 1.1) Footage import helpers
    // ==========================================================
    var __AUDIO_EXTS = {".wav":1, ".mp3":1, ".m4a":1, ".aac":1, ".flac":1, ".ogg":1};

    function _extLower(name) {
      try {
        var s = String(name || "");
        var idx = s.lastIndexOf(".");
        if (idx === -1) return "";
        return s.substring(idx).toLowerCase();
      } catch(e) { return ""; }
    }

    function _isAudioName(name) {
      var ex = _extLower(name);
      return (__AUDIO_EXTS[ex] === 1);
    }

    function _localMediaPathByName(fileName) {
      var base = String(__APP_DIR || "");
      if (!base) return "";
      var isA = _isAudioName(fileName);
      var sub = isA ? "/media/audio/" : "/media/video/";
      return base + sub + String(fileName);
    }

    function _singleAudioPathInMedia() {
      try {
        var dir = new Folder(String(__APP_DIR || "") + "/media/audio");
        if (!dir.exists) return "";
        var files = dir.getFiles(function (f) {
          try {
            if (!(f instanceof File)) return false;
            return _isAudioName(f.name);
          } catch(_) { return false; }
        });
        if (!files || files.length !== 1) return "";
        return files[0].fsName;
      } catch(e) { return ""; }
    }

    function _normalizeMediaNameForMatch(name) {
      try {
        var s = String(name || "");
        s = s.toLowerCase();
        // Windows can normalize away trailing spaces/dots in names.
        s = s.replace(/\s+\./g, ".");
        s = s.replace(/[ .]+$/g, "");
        s = s.replace(/\s+/g, " ");
        return s;
      } catch(_) { return ""; }
    }

    function _findMediaPathByNameFallback(expectedName, isAudio) {
      try {
        var dirPath = String(__APP_DIR || "") + (isAudio ? "/media/audio" : "/media/video");
        var dir = new Folder(dirPath);
        if (!dir.exists) return "";

        var files = dir.getFiles(function (f) {
          try { return (f instanceof File); } catch(_) { return false; }
        });
        if (!files || files.length === 0) return "";

        var expectedLower = String(expectedName || "").toLowerCase();
        for (var i = 0; i < files.length; i++) {
          try {
            if (String(files[i].name || "").toLowerCase() === expectedLower) {
              return files[i].fsName;
            }
          } catch(_) {}
        }

        var expectedNorm = _normalizeMediaNameForMatch(expectedName);
        if (!expectedNorm) return "";
        var matched = [];
        for (var j = 0; j < files.length; j++) {
          try {
            var candNorm = _normalizeMediaNameForMatch(files[j].name || "");
            if (candNorm === expectedNorm) matched.push(files[j]);
          } catch(_) {}
        }
        if (matched.length === 1) return matched[0].fsName;
      } catch(_) {}
      return "";
    }

    // ✅ PATH FIX: treat "/app/..." as invalid local path on Windows -> resolve via APP_DIR
    function _looksLikeUnixAbsPath(p) {
      try {
        var s = String(p || "");
        return (s.length >= 2 && s.charAt(0) === "/" && s.indexOf(":\\") === -1);
      } catch(e) { return false; }
    }

    function _isWindowsHost() {
      try {
        var os = String($.os || "").toLowerCase();
        return os.indexOf("windows") !== -1;
      } catch(_) { return false; }
    }

    function _shouldResolveViaAppDir(filePath) {
      var fp = String(filePath || "");
      if (!fp || fp === "") return true;
      if (fp.indexOf("http://") === 0 || fp.indexOf("https://") === 0) return true;
      if (fp.indexOf("s3://") === 0) return true;
      // Linux-style absolute paths like /app/... are invalid on Windows render node,
      // but valid on macOS local AE. Only force APP_DIR mapping on Windows host.
      if (_looksLikeUnixAbsPath(fp) && _isWindowsHost()) return true;
      return false;
    }

    function ensureFootageItem(src) {
      if (!src) return null;
      var nm = src.file_name;
      var fp = src.file_path;

      var existing = findFootageByName(nm);
      if (existing) return existing;

      if (_shouldResolveViaAppDir(fp)) {
        var local = _localMediaPathByName(nm);
        if (local && local !== "") {
          fp = local;
          logLine("INFO", "resolved local media path via APP_DIR name=" + nm + " -> " + fp);
        } else {
          logLine("ERR", "footage missing local path and APP_DIR resolve failed name=" + nm + " fp=" + String(fp));
          return null;
        }
      }

      try {
        var f = new File(fp);
        var isAudio = _isAudioName(nm);
        if (!f.exists && !isAudio) {
          var altAny = _findMediaPathByNameFallback(nm, _isAudioName(nm));
          if (altAny && altAny !== "") {
            logLine("WARN", "media fallback by normalized filename expected=" + nm + " actual=" + altAny);
            f = new File(altAny);
          }
        }
        // Strict audio contract: never auto-substitute a different audio file.
        if (!f.exists && isAudio) {
          logLine("ERR", "audio strict missing expected file name=" + nm + " path=" + fp);
          return null;
        }
        if (!f.exists) {
          logLine("ERR", "footage file not found path=" + fp + " name=" + nm);
          return null;
        }
        var io = new ImportOptions(f);
        var it = project.importFile(io);
        try { it.name = nm; } catch(_) {}
        logLine("INFO", "footage imported name=" + nm + " path=" + fp);
        return it;
      } catch(e) {
        logErr("import footage failed name=" + nm + " path=" + fp, e);
        return null;
      }
    }

    // ==========================================================
    // 2) Helpers
    // ==========================================================
    function interpFromCode(code) {
      if (code === "6614") return KeyframeInterpolationType.HOLD;
      if (code === "6612") return KeyframeInterpolationType.LINEAR;
      return KeyframeInterpolationType.BEZIER;
    }

    function applyValue(prop, data, ctx) {
      if (!prop || !data) return;

      if (data.expression && (!data.keyframes || data.keyframes.length === 0) && data.value === null) {
        try { prop.expression = data.expression; }
        catch(e) { logErr("expr set failed ctx=" + ctx, e); }
        return;
      }

      if (data.value !== null && (!data.keyframes || data.keyframes.length === 0)) {
        try {
          if (data.expression) prop.expression = data.expression;
          else prop.setValue(data.value);
        } catch(e2) { logErr("value set failed ctx=" + ctx, e2); }
        return;
      }

      if (data.keyframes && data.keyframes.length > 0) {
        try { while (prop.numKeys > 0) prop.removeKey(1); } catch(_) {}

        for (var k = 0; k < data.keyframes.length; k++) {
          var kf = data.keyframes[k];
          try {
            var keyIdx = prop.addKey(kf.t);
            prop.setValueAtKey(keyIdx, kf.v);

            var inInterp = interpFromCode(kf.iit);
            var outInterp = interpFromCode(kf.oit);
            try { prop.setInterpolationTypeAtKey(keyIdx, inInterp, outInterp); } catch(_) {}

            try {
              var easesIn = [];
              var easesOut = [];

              if (kf.ease_in && kf.ease_in.length > 0) {
                for (var ei = 0; ei < kf.ease_in.length; ei++) {
                  easesIn.push(new KeyframeEase(kf.ease_in[ei].speed, kf.ease_in[ei].influence));
                }
              }
              if (kf.ease_out && kf.ease_out.length > 0) {
                for (var eo = 0; eo < kf.ease_out.length; eo++) {
                  easesOut.push(new KeyframeEase(kf.ease_out[eo].speed, kf.ease_out[eo].influence));
                }
              }

              if (easesIn.length > 0 || easesOut.length > 0) {
                if (easesIn.length === 0) easesIn = easesOut;
                if (easesOut.length === 0) easesOut = easesIn;
                prop.setTemporalEaseAtKey(keyIdx, easesIn, easesOut);
              }
            } catch(_) {}

          } catch(e3) {
            logErr("kf set failed ctx=" + ctx + " k=" + k, e3);
          }
        }
      }
    }

    function resolveBlendingModeByCode(code) {
      try { if (String(code) === "5212") return BlendingMode.NORMAL; } catch(e) {}
      try { if (String(code).toLowerCase() === "screen") return BlendingMode.SCREEN; } catch(e2) {}
      return null;
    }

    function resolveJustificationByCode(code) {
      try { if (String(code) === "7415") return ParagraphJustification.CENTER_JUSTIFY; } catch(e) {}
      return null;
    }

    function safeProp(group, matchOrName) {
      if (!group) return null;
      try { return group.property(matchOrName); } catch (_) { return null; }
    }

    // ==========================================================
    // 2.1) TextDocument apply (BASE + PER-CHAR)
    // (kept as-is; your pipeline already handles it)
    // ==========================================================
    function applyTextBaseAndCharStyles(layer, lData) {
      if (!layer || !lData || lData.type !== "text") return;

      var td = (lData.text_data ? lData.text_data : null);
      if (!td) return;

      var textProps = null;
      try { textProps = layer.property("ADBE Text Properties"); } catch(e) { textProps = null; }
      if (!textProps) { logLine("ERR", "no Text Properties layer=" + layer.name); return; }

      var textDocProp = safeProp(textProps, "ADBE Text Document");
      if (!textDocProp) { logLine("ERR", "no Text Document prop layer=" + layer.name); return; }

      var base = td.text_base;
      var chars = td.char_styles_ungrouped;
      if (!base && !chars) return;

      try {
        var textDoc = textDocProp.value;
        try { textDoc.resetCharStyle(); } catch(_) {}

        if (base) {
          try { if (base.font !== undefined) textDoc.font = base.font; } catch(_) {}
          try { if (base.fontSize !== undefined) textDoc.fontSize = base.fontSize; } catch(_) {}
          try { if (base.applyFill !== undefined) textDoc.applyFill = !!base.applyFill; } catch(_) {}
          try { if (base.fillColor !== undefined) textDoc.fillColor = base.fillColor; } catch(_) {}
          try { if (base.applyStroke !== undefined) textDoc.applyStroke = !!base.applyStroke; } catch(_) {}
          try { if (base.strokeWidth !== undefined) textDoc.strokeWidth = base.strokeWidth; } catch(_) {}
          try { if (base.strokeColor !== undefined) textDoc.strokeColor = base.strokeColor; } catch(_) {}
          try { if (base.tracking !== undefined) textDoc.tracking = base.tracking; } catch(_) {}
          try { if (base.leading !== undefined) textDoc.leading = base.leading; } catch(_) {}
