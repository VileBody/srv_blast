# syntax=docker/dockerfile:1
FROM python:3.13-alpine

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONPATH=/app

WORKDIR /app

RUN apk add --no-cache bash ca-certificates ffmpeg

COPY requirements.infra.txt /app/requirements.infra.txt
RUN pip install --no-cache-dir -r /app/requirements.infra.txt

COPY . /app
