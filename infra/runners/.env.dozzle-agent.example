# Required: this node private IP reachable from the central Dozzle host.
# In prod-path deploys, deploy_branch.sh bootstraps this from the server
# private address when .env.dozzle-agent is absent or this value is empty.
DOZZLE_AGENT_BIND_HOST=
DOZZLE_AGENT_PORT=7007
# Required: a stable node label shown in Dozzle. In prod-path deploys this is
# bootstrapped from ORCHESTRATOR_NODE_NAME, then hostname.
DOZZLE_AGENT_HOSTNAME=
DOZZLE_AGENT_LEVEL=info
