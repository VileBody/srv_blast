# .env.example — пример переменных окружения для локального запуска
# НЕ кладите сюда реальные ключи/секреты

# NOTE:
# Геометрию AE-проекта (width/height/fps/pixelAspect) задаём в
# config/styles/<style-pack>/project_settings_template.json.
# Эти TARGET_* — только дефолты пайплайна (не обязаны совпадать с AE-шаблоном).
#
# Style pack (набор конфигов/пресетов)
# - хранится в config/styles/<pack>/
# - по умолчанию: pop-music
AE_STYLE_PACK=pop-music
TARGET_WIDTH=1080
TARGET_HEIGHT=1080

# Gemini API
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL_PLANNING=gemini-2.5-pro
GEMINI_MODEL_SUBS=gemini-flash-latest

# Рабочие каталоги
PINS_DIR=./pins
DESCRIPTIONS_DIR=./descriptions
WORK_DIR=./work
OUTPUT_DIR=./output

# ElevenLabs (опционально)
ELEVENLABS_API_KEY=
ELEVEN_STT_MODEL=scribe_v1

# Провайдер субтитров: gemini (по умолчанию) или elevenlabs
SUBTITLES_PROVIDER=gemini

# S3 buckets (placeholders)
S3_BUCKET_OUTPUT_VIDEO=your-output-bucket
S3_BUCKET_SOURCE_VIDEO=your-source-bucket

# Опциональный исходящий прокси
#OUTBOUND_PROXY=
