# Bind host for local-only access behind nginx reverse proxy
OBS_BIND_HOST=127.0.0.1

# Ports
GRAFANA_PORT=13000
PROMETHEUS_PORT=19090
ALERTMANAGER_PORT=19093
LOKI_PORT=13100

# Credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# Storage / retention
PROMETHEUS_RETENTION=30d
LOKI_RETENTION=744h

# Runtime labels
OBS_ENV=prod

# Existing app docker network (must include orchestrator containers)
BLAST_DOCKER_NETWORK=blast_mj_final_default

# Alertmanager -> Telegram
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
