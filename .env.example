# =============================================================================
# Blast — Docker Compose environment (example)
#
# IMPORTANT:
# - Do NOT commit real secrets to git. Keep them only in your real `.env`.
# - MODE is required and must be exactly: dev | prod
# - Gemini model contract is explicit-only for primary stage models.
# - Runtime fallback is optional via GEMINI_MODEL_FALLBACK.
# =============================================================================

# ===== Runtime (required) =====
MODE=prod

# ===== Gemini (required) =====
GEMINI_API_KEY=
OUTBOUND_PROXY=
GEMINI_TEMPERATURE=1.0
GEMINI_TIMEOUT_S=90
# LLM_PROVIDER_MODE: gemini | openrouter | hedged
# Current prod policy: keep this as `gemini`.
# openrouter/hedged are kept for explicit opt-in testing only.
LLM_PROVIDER_MODE=gemini
LLM_HEDGE_DELAY_S=60
OPENROUTER_API_KEY=
# Kept explicit for tooling parity; not used while LLM_PROVIDER_MODE=gemini.
OPENROUTER_TIMEOUT_S=60
# Model/schema validation retries are stage-local and internal (no whole-job replay).
TEXT_LAYER_TIME_SHIFT_S=0.3
AUDIO_FADE_IN_S=0.5
AUDIO_FADE_OUT_S=0.5
AUDIO_FADE_MIN_DB=-48
OVERLAY_ENABLED=0
OVERLAY_OPACITY=15
OVERLAY_SOURCE_MODE=inventory
OVERLAY_INVENTORY_JSON=
OVERLAY_MATCH_MODE=by_style
OVERLAY_SELECTION_SEED=
OVERLAY_S3_BUCKET=
OVERLAY_S3_PREFIX=overlays/
FOOTAGE_SHAKE_ENABLED=1

# Explicit model contract (required)
GEMINI_MODEL_STAGE1=gemini-2.5-pro
GEMINI_MODEL_SUBTITLES=gemini-3-pro-preview
GEMINI_MODEL_FOOTAGE=gemini-3.1-flash-preview
# Optional runtime fallback model for transient 503/429 capacity errors.
# Set to `off` to disable fallback.
GEMINI_MODEL_FALLBACK=gemini-3-flash-preview
GEMINI_UPLOAD_MAX_ATTEMPTS=4
GEMINI_UPLOAD_BACKOFF_BASE_S=1
GEMINI_UPLOAD_BACKOFF_MAX_S=8
STAGE2_TIMING_MODE=hybrid
STAGE2_FAST_START_SECONDS=6
# If SDK supports ThinkingConfig.thinking_budget, this caps "thinking" budget.
# With unsupported SDK versions this value is ignored with warning in logs.
GEMINI_MAX_THINKING_TOKENS=40000
# Optional hard cap for generated output tokens.
GEMINI_MAX_OUTPUT_TOKENS=
# Stage1A forced-alignment: if transcript timeline drifts too far from real audio duration,
# one rework attempt is made with TRANSCRIBE_ATTEMPT_1 + comment(fact_dur, transcribed_dur).
STAGE1A_DURATION_DRIFT_MIN_WORDS=80
STAGE1A_DURATION_DRIFT_ABS_SEC=12.0
STAGE1A_DURATION_DRIFT_REL=0.20
# Stage1 clip window bounds (seconds) used across validation + prompts.
CLIP_WINDOW_MIN_SECONDS=13
CLIP_WINDOW_MAX_SECONDS=30

# Optional overrides (if empty -> GEMINI_MODEL_STAGE1 will be used)
GEMINI_MODEL_STAGE1_ASR=
GEMINI_MODEL_STAGE1_SCENARIO=

# Legacy / NOT USED (kept only as a reminder; do not rely on these)
# GEMINI_MODEL=
# GEMINI_FALLBACK_AFTER_RETRIES=

# ===== Paths (inside container) =====
PINS_DIR=/app/pins
DESCRIPTIONS_DIR=/app/descriptions
WORK_DIR=/app/work
OUTPUT_DIR=/app/output

# Shared catalog inputs (inside container)
FOOTAGE_DIR=/app/footage
FOOTAGE_DESCRIPTIONS_DIR=/app/descriptions
STATIC_ASSETS_SOURCE_INDEX_JSON=/app/data/static_assets_index_1to1.json
STATIC_ASSETS_INDEX_JSON=/app/data/static_assets_index_1to1.json
STATIC_ASSETS_ENRICH_INDEX_JSON=/app/data/static_assets_index_1to1.json
FOOTAGE_S3_PREFLIGHT_MODE=strict

# Shared catalog outputs (inside container)
FOOTAGE_INVENTORY_OUT=/app/data/footage_inventory.json
DESCRIPTIONS_BUNDLE_OUT=/app/pins/descriptions_bundle.json

# Shared catalog paths (used by mlcore + orchestrator startup)
FOOTAGE_INVENTORY_JSON=/app/data/footage_inventory.json
DESCRIPTIONS_BUNDLE_PATH=/app/pins/descriptions_bundle_selected.json

# Footage blacklist — JSON array of file_name strings to always exclude from selection.
# To find file_names: check clips_manifest.json in the job output directory.
# Example: [\"Rock__1234567890\", \"Pop__9876543210\"]
FOOTAGE_BLACKLIST_PATH=/app/data/video_blacklist.json

# Bundle tuning (optional)
DESCRIPTIONS_BUNDLE_MAX_ASSETS=
DESCRIPTIONS_BUNDLE_INLINE_MAX_CHARS=250000

# ===== Redis (store) =====
REDIS_HOST=
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=

# ===== Celery (broker/backend) =====
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_QUEUE_BUILD=build
CELERY_QUEUE_RENDER=render

# Optional: Redis key prefix
JOBSTORE_PREFIX=blast
# JobStore retention (seconds). 0 disables TTL.
JOBSTORE_JOB_TTL_SECONDS=1209600
JOBSTORE_IDEMPOTENCY_TTL_SECONDS=1209600
# Auto-clean local per-job logs in output/jobs/*/out/logs (seconds, 0 disables).
JOB_LOG_RETENTION_SECONDS=3600

# LLM workers admission (runtime defaults; overridable in /admin/llm-workers)
# Current cutover default: gemini-only (sdk enabled; openrouter/hybrid disabled).
LLM_WORKER_SDK_ENABLED=1
LLM_WORKER_SDK_WEIGHT=1
LLM_WORKER_SDK_MAX_INFLIGHT=4
LLM_WORKER_OPENROUTER_ENABLED=0
LLM_WORKER_OPENROUTER_WEIGHT=1
LLM_WORKER_OPENROUTER_MAX_INFLIGHT=4
LLM_WORKER_HYBRID_ENABLED=0
LLM_WORKER_HYBRID_WEIGHT=1
LLM_WORKER_HYBRID_MAX_INFLIGHT=4

# ===== Windows render node (prod dispatch) =====
WINDOWS_RENDER_URL=
WINDOWS_RENDER_URLS=
WINDOWS_TIMEOUT_S=300
WINDOWS_POLL_INTERVAL_S=2.0
WINDOWS_POLL_TIMEOUT_S=3600
WINDOWS_NODE_LEASE_TTL_S=7200
S3_JOB_ARTIFACTS_UPLOAD=0
S3_BUCKET_JOB_ARTIFACTS=
S3_JOB_ARTIFACTS_PREFIX=ae_jobs_artifacts
S3_JOB_ARTIFACTS_DELETE_LOCAL_AFTER_UPLOAD=0

# ===== S3 (storage) =====
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_RAW_AUDIO=
S3_BUCKET_OUTPUT_VIDEO=
S3_BUCKET_ASSET_STORAGE=
S3_REGION=ru-1
S3_ASSET_PREFIX=pinterest_collection/selected

# ===== MinIO (local mirror for assets, optional) =====
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_REGION=ru-1
MINIO_ENDPOINT_URL=http://127.0.0.1:19100
MINIO_BUCKET_ASSET_STORAGE=
MINIO_BIND_HOST=127.0.0.1
MINIO_API_PORT=19100
MINIO_CONSOLE_PORT=19101

# ===== Asset UI (S3 browser) =====
# Internal service port in container (mapped to host 127.0.0.1:18173 via docker-compose).
ASSET_UI_PORT=8100
ASSET_UI_UPLOAD_MAX_MB=512
ASSET_UI_TRASH_PREFIX=_trash
ASSET_UI_PRESIGN_TTL_S=900

# ===== Orchestrator URL (inside docker network, optional) =====
ORCHESTRATOR_URL=http://orchestrator-api:8000
ORCHESTRATOR_PUBLIC_URL=http://orchestrator-api:8000

# ===== Telegram bot (long polling) =====
# Set real tokens only in server `.env` (do not commit secrets).
TG_BOT_TOKEN=
TG_BOT_PUBLIC_TOKEN=
# Optional: source bot token used by public bot to fetch preview videos
# when preview_file_id belongs to another bot (e.g. team bot).
TG_PREVIEW_SOURCE_BOT_TOKEN=
BOT_POLL_INTERVAL_S=5
BOT_STATUS_UPDATE_INTERVAL_S=20
BOT_TMP_DIR=/app/work/tg_tmp
BOT_TMP_DIR_PUBLIC=/app/work/tg_tmp_public
BOT_MAX_AUDIO_MB=5

# TG Redis state retention and cleanup loops
TG_STATE_TTL_H=720
TG_STATE_CLEANUP_INTERVAL_S=900
TG_STATE_CLEANUP_BATCH_SIZE=200
TG_STATE_INDEX_CLEANUP_BATCH_SIZE=500

# Filesystem hygiene (/app/work and /app/output/jobs)
BOT_FS_CLEANUP_INTERVAL_S=900
BOT_FS_CLEANUP_BATCH_SIZE=2000
BOT_TMP_INCOMING_RETENTION_H=24
BOT_TMP_PREPARED_RETENTION_H=24
BOT_TMP_RESULT_RETENTION_H=6
BOT_OUTPUT_ARTIFACT_RETENTION_H=24
BOT_OUTPUT_DEBUG_ARTIFACT_RETENTION_H=168
# Comma-separated glob patterns retained for extended debug window.
BOT_OUTPUT_ARTIFACT_ALLOWLIST=stage2_subtitles.json,stage2_subtitles_*.json,gemini_raw_stage2_subtitles_*.json,stage2_footage.json,stage2_footage_*.json
# Optional proxy for Telegram Bot API traffic (downloads + uploads).
# Example: http://user:pass@proxy-host:3128
TG_FILE_PROXY_URL=
TG_STATE_PREFIX=blast:tg:chat_state
TG_PUBLIC_STATE_PREFIX=blast:tg:public:chat_state
SUBSCRIPTION_CHANNEL=@impulsemarketing
MANAGER_CHAT_ID=0
SURVEY_URL=https://forms.yandex.ru/u/69c52ce695add5c0264676e3
# 1 = send project archive link (S3/presigned URL) in chat, without uploading archive file to Telegram
TG_SEND_PROJECT_ARCHIVE=0
# comma-separated telegram usernames allowed to receive artifacts link
# example: @nikitaimpulse,@whoistvoidiller
ARTIFACTS_ALLOWLIST=

# ===== Credits DB / admin panel (tg_bot_public) =====
# Preferred: full DSN via CREDITS_DB_URL.
# Alternative: POSTGRES_* values below (code builds DSN automatically).
CREDITS_DB_URL=
# Legacy sqlite source path for one-time migration script only.
CREDITS_DB_PATH=/app/work/credits.db
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_SSLMODE=prefer
ADMIN_PANEL_PORT=8080
TG_BOT_PUBLIC_ADMIN_BIND_PORT=18081
ADMIN_PANEL_PASSWORD=changeme
TWC_TOKEN=
TWC_RENDER_SOURCE_SERVER_ID=
TWC_RENDER_FIREWALL_GROUP_ID=
TWC_RENDER_NAME_PREFIX=blast-render-node
TWC_RENDER_WAIT_ON_TIMEOUT_S=1800
TWC_RENDER_WAIT_API_TIMEOUT_S=900
INITIAL_CREDITS=2

# ===== T-Bank payments (tg_bot_public) =====
TBANK_TERMINAL_KEY=
TBANK_PASSWORD=
TBANK_NOTIFY_URL=
OFFER_URL=

# ===== Debug flags (optional) =====
DEBUG_SAVE_LLM=1

# ===== Optional / future (currently unused by code) =====
SUBTITLES_PROVIDER=gemini
TARGET_WIDTH=1080
TARGET_HEIGHT=1920
ELEVENLABS_API_KEY=
ELEVEN_STT_MODEL=scribe_v1
TG_API_ID=
TG_API_HASH=
TG_SESSION=
