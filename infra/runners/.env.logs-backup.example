# Enable/disable the logs backup pipeline on this node.
LOG_BACKUP_ENABLED=false

# Node identity for cursors and S3 paths.
LOG_BACKUP_NODE_NAME=blast-ops-1
LOG_BACKUP_NODE_ROLE=infra-ops

# PostgreSQL DSN (same DB, logs schema).
LOG_BACKUP_DB_DSN=postgresql://gen_user:password@db.example:5432/default_db?sslmode=prefer

# S3 target.
LOG_BACKUP_S3_BUCKET=f7cef916-asset-storage
LOG_BACKUP_S3_PREFIX=logs-backup
LOG_BACKUP_RETENTION_DAYS=180
LOG_BACKUP_RAW_RETENTION_DAYS=30
LOG_BACKUP_NORM_RETENTION_DAYS=180
LOG_BACKUP_BACKFILL_DAYS=30
LOG_BACKUP_S3_CHUNK_SIZE=5000

# Collectors.
LOG_BACKUP_LOKI_ENABLED=true
LOG_BACKUP_LOKI_URL=http://127.0.0.1:13100
LOG_BACKUP_LOKI_QUERY={}
LOG_BACKUP_LOKI_LIMIT=5000
LOG_BACKUP_DOCKER_ENABLED=true
LOG_BACKUP_MAX_LAG_MIN=90

# Required S3 credentials (reused existing contract).
S3_ENDPOINT_URL=https://s3.twcstorage.ru
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=ru-1
