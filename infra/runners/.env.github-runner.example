GH_RUNNER_REPO_URL=https://github.com/VileBody/srv_blast

# Personal Access Token with scope: repo (or org runner token flow if preferred)
GH_RUNNER_ACCESS_TOKEN=

GH_RUNNER_NAME=blast-deploy-01
# For split rollout (runner only on blast-ops) use blast-deploy-infra.
GH_RUNNER_LABELS=self-hosted,blast-deploy-infra

# Absolute path to repo clone on the server.
BLAST_REPO_DIR=/opt/blast_mj_final
