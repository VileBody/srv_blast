          "instanceId": "lens_blur",
          "param": "iris_scale",
          "meaning": "blur pulse"
        },
        {
          "instanceId": "transform_rot",
          "param": "rotation",
          "meaning": "micro-tilt oscillation"
        },
        {
          "instanceId": "transform_shake",
          "param": "position",
          "meaning": "shake driver (expression + keys)"
        },
        {
          "instanceId": "transform_shake",
          "param": "scale_height",
          "meaning": "squeeze / vertical stretch"
        },
        {
          "instanceId": "zoom_blur",
          "param": "z_dist",
          "meaning": "zoom intensity pulse"
        }
      ],
