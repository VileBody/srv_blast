# Local generated data — footage/photo POOL + TAG caches.
# These are REGENERATED by "Активировать базу" (activate_footage_base) from the
# real sources of truth (S3 for the pool, Postgres footage_tags for tags). They
# MUST NOT be tracked: deploy does `git reset --hard`, which would revert a
# tracked cache to a stale committed copy and silently shrink/rot the pool.
data/footage_inventory.json
data/footage_inventory_selected.json
data/static_assets_index.json
data/static_assets_index_1to1.json
data/footage_tags_snapshot.json
data/photo_assets_index_1to1.json
data/photo_inventory.json
data/photo_tags_snapshot.json
# diagnostic report outputs (footage_pool_reconcile / bucket_pool_report / alias_report)
data/footage_pool_reconcile.json
data/footage_bucket_pool_report.json
data/tag_alias_report.json
video_database.json
pins2/

# Landing local import artifacts (do not deploy / do not track)
landing/*.rar
landing/tmp/
landing/tmp_rar_extract/
landing/assets/*.mp4

# Local packed context dumps
repomix_*_flow.md

# Infra runtime secrets/state
infra/runners/dozzle_data/
infra/timeweb/**/.terraform/
infra/timeweb/**/.terraform.lock.hcl
infra/timeweb/**/terraform.tfstate
infra/timeweb/**/terraform.tfstate.*
