{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "type": "stat",
      "title": "Dispatch Accepted (30m)",
      "id": 1,
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(increase(dispatch_attempt_total{outcome=\"accepted\"}[30m]))", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}},
      "fieldConfig": {"defaults": {}, "overrides": []}
    },
    {
      "type": "stat",
      "title": "Poll Timeouts (30m)",
      "id": 2,
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(increase(render_poll_timeout_total[30m]))", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}},
      "fieldConfig": {"defaults": {}, "overrides": []}
    },
    {
      "type": "stat",
      "title": "Dispatch Recovery (30m)",
      "id": 3,
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(increase(dispatch_recovery_total{outcome=\"recovered\"}[30m]))", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}},
      "fieldConfig": {"defaults": {}, "overrides": []}
    },
    {
      "type": "stat",
      "title": "Dispatch Success Ratio (30m)",
      "id": 4,
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(increase(dispatch_attempt_total{outcome=\"accepted\"}[30m])) / clamp_min(sum(increase(dispatch_attempt_total{outcome=~\"accepted|failed|retry|failed_no_node\"}[30m])), 1)", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}},
      "fieldConfig": {"defaults": {"unit": "percentunit"}, "overrides": []}
    },
    {
      "type": "timeseries",
      "title": "Dispatch Outcomes by Node",
      "id": 5,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum by (node, outcome) (rate(dispatch_attempt_total[5m]))", "legendFormat": "{{node}} {{outcome}}", "refId": "A"}],
      "fieldConfig": {"defaults": {}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}}
    },
    {
      "type": "timeseries",
      "title": "Render Poll Outcomes by Node",
      "id": 6,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum by (node, outcome) (rate(render_poll_total[5m]))", "legendFormat": "{{node}} {{outcome}}", "refId": "A"}],
      "fieldConfig": {"defaults": {}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}}
    },
    {
      "type": "logs",
      "title": "Dispatch/Render Logs",
      "id": 7,
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {"expr": "{service=~\"orchestrator-api|worker-render\"} |= \"obs_event\" |= \"dispatch\"", "refId": "A"}
      ],
      "options": {"showLabels": true, "wrapLogMessage": true}
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["blast", "dispatch"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "timezone": "browser",
  "title": "Dispatch Render",
  "version": 1
}
