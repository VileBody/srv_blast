# Copy to .env.rust-gen.iac. It is ignored by git.
# TWC_TOKEN can be copied from the existing blast_mj_final/.env.iac. Do not copy its Windows image ID.
TWC_TOKEN=replace_me
# Current Timeweb discovery: Debian 12 is os_id 95. Re-check before a new region rollout.
TWC_LINUX_OS_ID=95
TWC_PRESET_ID=4807
TWC_AZ=msk-1
TWC_SERVER_NAME=blast-rust-gen-1
TWC_ENABLE_PUBLIC_IPV4=true
# Remote Terraform state. Use a private existing Timeweb S3 bucket; credentials
# stay in AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY, never in this file.
TWC_STATE_BUCKET=replace_with_private_bucket
TWC_STATE_KEY=terraform/rust-gen-node.tfstate
TWC_STATE_ENDPOINT=https://s3.twcstorage.ru
TWC_STATE_REGION=ru-1
# Comma-separated, restricted CIDRs only. The production orchestrator and deploy runner must be present.
RUST_GEN_MANAGER_API_CIDRS=203.0.113.10/32
RUST_GEN_SSH_ALLOWED_CIDRS=203.0.113.10/32
# Optional Timeweb project and SSH key IDs.
# TWC_PROJECT_ID=123456
# TWC_SSH_KEY_IDS=123,456
