      "paramMeta": {
        "radius": {
          "type": "float"
        },
        "exposure": {
          "type": "float"
        },
        "threshold": {
          "type": "float"
        }
      }
    },
    "ef_directional_blur": {
      "description": "Directional Blur (built-in) – motion smear",
      "propertyTree": {
        "matchName": "ADBE Motion Blur",
        "name": "Directional Blur"
